---
import { menuLinks } from "@/site-config";
import ThemeToggle from "../ThemeToggle.astro";

const url = new URL(Astro.request.url);

const isActive = (path: string) => {
	if (path === "/") return url.pathname === "/";
	return url.pathname === path || url.pathname.startsWith(path);
};
---

<header class="site-header" id="main-header">
	<a href="/" class="wordmark">Anjay Goel</a>
	<div class="header-right">
		<nav class="nav" aria-label="Primary">
			{
				menuLinks.map((link) => (
					<a
						aria-current={isActive(link.path) ? "page" : false}
						class:list={[{ active: isActive(link.path) }]}
						data-astro-prefetch
						href={link.path}
					>
						{link.title}
					</a>
				))
			}
		</nav>
		<ThemeToggle />
	</div>
</header>

<style>
	.site-header {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 24px;
		margin-bottom: 72px;
	}
	.wordmark {
		font-family: var(--font-serif);
		font-size: 17px;
		font-weight: 500;
		letter-spacing: -0.01em;
		color: hsl(var(--theme-text));
		transition: color 0.2s ease, border-color 0.2s ease;
	}
	.wordmark:hover {
		color: hsl(var(--theme-accent));
	}
	.header-right {
		display: flex;
		align-items: baseline;
		gap: 22px;
	}
	.nav {
		display: flex;
		gap: 22px;
		font-family: var(--font-sans);
		font-size: 13.5px;
		color: hsl(var(--theme-text) / 0.6);
	}
	.nav a {
		transition: color 0.2s ease, border-color 0.2s ease;
	}
	.nav a:hover {
		color: hsl(var(--theme-accent));
	}
	.nav a.active {
		color: hsl(var(--theme-text));
		border-bottom: 1px solid hsl(var(--theme-accent));
		padding-bottom: 2px;
	}

	@media (max-width: 720px) {
		.site-header {
			margin-bottom: 48px;
			flex-wrap: wrap;
			gap: 14px;
		}
		.header-right {
			flex-wrap: wrap;
			gap: 14px;
		}
		.nav {
			gap: 16px;
			font-size: 13px;
			flex-wrap: wrap;
		}
	}

	@media (max-width: 420px) {
		.site-header {
			margin-bottom: 36px;
			gap: 14px;
		}
		.wordmark {
			font-size: 16px;
		}
		.header-right {
			gap: 10px;
		}
		.nav {
			gap: 12px;
			font-size: 12.5px;
		}
	}
</style>
