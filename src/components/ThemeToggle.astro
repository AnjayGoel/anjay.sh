<button class="theme-toggle" id="theme-toggle" type="button" aria-label="Toggle theme">
	<span class="icon" aria-hidden="true">☾</span>
	<span class="label">Dark</span>
</button>

<style is:global>
	.theme-toggle {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		padding: 6px 12px;
		border-radius: 999px;
		background: var(--accent-soft);
		color: hsl(var(--theme-text-muted));
		border: 1px solid transparent;
		font-family: var(--font-sans);
		font-size: 12px;
		font-weight: 500;
		cursor: pointer;
		transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease;
	}
	.theme-toggle:hover {
		background: var(--accent-soft-strong);
		color: hsl(var(--theme-accent));
	}
	.theme-toggle .icon {
		font-size: 13px;
		line-height: 1;
	}
	.theme-toggle:focus-visible {
		outline: 2px solid hsl(var(--theme-accent));
		outline-offset: 3px;
	}
</style>

<script>
	const setup = () => {
		const r = document.documentElement;
		const btn = document.getElementById("theme-toggle") as HTMLButtonElement | null;
		if (!btn || btn.dataset.bound === "1") return;
		btn.dataset.bound = "1";
		const iconEl = btn.querySelector(".icon") as HTMLElement | null;
		const labelEl = btn.querySelector(".label") as HTMLElement | null;
		const upd = () => {
			const isDark = r.dataset.theme === "dark";
			if (labelEl) labelEl.textContent = isDark ? "Light" : "Dark";
			if (iconEl) iconEl.textContent = isDark ? "☀" : "☾";
		};
		upd();
		btn.addEventListener("click", () => {
			const next = r.dataset.theme === "dark" ? "light" : "dark";
			r.dataset.theme = next;
			try { localStorage.setItem("theme", next); } catch (e) {}
			upd();
			document.dispatchEvent(new CustomEvent("theme-change", { detail: { theme: next } }));
		});
	};
	setup();
	document.addEventListener("astro:page-load", setup);
</script>
