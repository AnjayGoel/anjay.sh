<button class="theme-toggle" id="theme-toggle" type="button" aria-label="Toggle theme">
	<span class="icon" aria-hidden="true">☾</span>
	<span class="label">dark</span>
</button>

<style is:global>
	.theme-toggle {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		padding: 6px 12px;
		border-radius: 999px;
		background: rgba(138, 68, 35, 0.1);
		color: hsl(var(--theme-text-muted));
		border: 1px solid transparent;
		font-family: var(--font-sans);
		font-size: 12px;
		font-weight: 500;
		cursor: pointer;
		transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease;
	}
	:root[data-theme="dark"] .theme-toggle {
		background: rgba(200, 151, 97, 0.12);
	}
	.theme-toggle:hover {
		background: rgba(138, 68, 35, 0.18);
		color: hsl(var(--theme-accent));
	}
	:root[data-theme="dark"] .theme-toggle:hover {
		background: rgba(200, 151, 97, 0.22);
	}
	.theme-toggle .icon {
		font-size: 13px;
		line-height: 1;
	}
	.theme-toggle:focus-visible {
		outline: 2px solid hsl(var(--theme-accent));
		outline-offset: 3px;
	}
</style>

<script>
	(() => {
		const r = document.documentElement;
		const btn = document.getElementById("theme-toggle");
		if (!btn) return;
		const iconEl = btn.querySelector(".icon") as HTMLElement | null;
		const labelEl = btn.querySelector(".label") as HTMLElement | null;
		const upd = () => {
			const isDark = r.dataset.theme === "dark";
			if (labelEl) labelEl.textContent = isDark ? "light" : "dark";
			if (iconEl) iconEl.textContent = isDark ? "☀" : "☾";
		};
		upd();
		btn.addEventListener("click", () => {
			const next = r.dataset.theme === "dark" ? "light" : "dark";
			r.dataset.theme = next;
			try {
				localStorage.setItem("theme", next);
			} catch (e) {}
			upd();
			// notify ThemeProvider so meta theme-color stays in sync
			document.dispatchEvent(
				new CustomEvent("theme-change", { detail: { theme: next } }),
			);
		});

		// keep icon/label in sync after view transitions
		document.addEventListener("astro:after-swap", upd);
	})();
</script>
