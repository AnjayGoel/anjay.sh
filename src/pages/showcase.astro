---
import PageLayout from "@/layouts/Base.astro";
import { Schema } from "astro-seo-schema";

const showcase: {
	name: string;
	href: string;
	stack: string;
	badge?: string;
	desc: string;
}[] = [
	{
		name: "RedScout",
		href: "https://github.com/AnjayGoel/RedScout",
		stack: "Go · Redis · CLI",
		badge: "OSS",
		desc:
			"Namespace-level Redis monitoring — breaks memory, TTLs, and ops/sec down by logical key prefix instead of server-wide aggregates.",
	},
	{
		name: "DashReels",
		href: "https://play.google.com/store/apps/details?id=com.dashtoon.video.reels&hl=en_IN",
		stack: "Android · Kotlin",
		badge: "1M+ installs",
		desc:
			"Short-form video Android app — free dramas across genres, personalised recommendations, low-latency playback over a flaky last mile.",
	},
	{
		name: "DashToon",
		href: "https://play.google.com/store/apps/details?id=com.dashtoon.app&hl=en_IN",
		stack: "Android · Kotlin",
		desc:
			"Comics & webtoons reader app — fluid panel-by-panel reading experience for vertical and traditional layouts.",
	},
	{
		name: "Stable Roommate (Generalised)",
		href: "https://github.com/AnjayGoel/stable-roommate-generalised",
		stack: "Python · Algorithms",
		badge: "OSS",
		desc:
			"Algorithm + small webapp grouping people into optimal teams. Generalises Irving's stable roommate matching to k-sized groups.",
	},
];
---

<Schema
	item={{
		"@context": "https://schema.org",
		"@type": "BreadcrumbList",
		itemListElement: [
			{
				"@type": "ListItem",
				position: 1,
				name: "Home",
				item: "https://anjay.sh",
			},
			{
				"@type": "ListItem",
				position: 2,
				name: "Showcase",
				item: "https://anjay.sh/showcase",
			},
		],
	}}
/>

<PageLayout meta={{ title: "Showcase" }}>
	<section class="work" aria-labelledby="work-label">
		<div class="section-label" id="work-label">Showcase</div>
		<p class="intro">
			A handful of projects I've built — open source tools, mobile apps shipped to millions, and the
			occasional algorithmic detour.
		</p>
		<ul class="work-list">
			{
				showcase.map((item) => (
					<li>
						<a href={item.href} rel="noreferrer" target="_blank">
							<div class="head">
								<span class="name">{item.name}</span>
								<span class="stack">{item.stack}</span>
								{item.badge && <span class="badge">{item.badge}</span>}
							</div>
							<p>{item.desc}</p>
						</a>
					</li>
				))
			}
		</ul>
	</section>
</PageLayout>

<style>
	.work {
		margin-bottom: 88px;
	}
	.section-label {
		font-family: var(--font-sans);
		font-size: 11.5px;
		font-weight: 500;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: hsl(var(--theme-text) / 0.6);
		margin-bottom: 36px;
	}
	.intro {
		font-family: var(--font-serif);
		font-size: 17.5px;
		line-height: 1.7;
		color: hsl(var(--theme-text));
		margin: 0 0 36px;
		max-width: 60ch;
		text-wrap: pretty;
	}

	ul.work-list {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	ul.work-list li {
		padding: 22px 0;
		border-top: 1px solid var(--hairline);
		transition: border-color 0.35s ease;
	}
	ul.work-list li:last-child {
		border-bottom: 1px solid var(--hairline);
	}
	ul.work-list a {
		text-decoration: none;
		color: inherit;
		display: block;
	}
	ul.work-list .head {
		display: flex;
		align-items: baseline;
		gap: 14px;
		flex-wrap: wrap;
		margin-bottom: 6px;
	}
	ul.work-list .name {
		font-family: var(--font-serif);
		font-size: 21px;
		font-weight: 600;
		letter-spacing: -0.012em;
		color: hsl(var(--theme-text));
		transition: color 0.2s ease;
		word-wrap: break-word;
		overflow-wrap: anywhere;
	}
	ul.work-list a:hover .name,
	ul.work-list a:focus-visible .name {
		color: hsl(var(--theme-accent));
	}
	ul.work-list .stack {
		font-family: var(--font-mono);
		font-size: 11px;
		color: hsl(var(--theme-text) / 0.6);
		font-variant-numeric: tabular-nums;
		font-feature-settings: "tnum";
	}
	ul.work-list .badge {
		font-family: var(--font-mono);
		font-size: 10px;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: hsl(var(--theme-accent));
		background: var(--accent-soft);
		padding: 2px 8px;
		border-radius: 2px;
	}
	ul.work-list p {
		font-size: 14.5px;
		color: hsl(var(--theme-text-muted));
		margin: 6px 0 0;
		max-width: 60ch;
		line-height: 1.55;
		word-wrap: break-word;
		overflow-wrap: anywhere;
	}
	ul.work-list a:focus-visible {
		outline: 2px solid hsl(var(--theme-accent));
		outline-offset: 4px;
		border-radius: 4px;
	}

	@media (max-width: 720px) {
		.intro {
			font-size: 17px;
			margin-bottom: 28px;
		}
	}
	@media (max-width: 420px) {
		.section-label {
			margin-bottom: 26px;
		}
		.work {
			margin-bottom: 56px;
		}
		.intro {
			font-size: 16.5px;
		}
		ul.work-list .name {
			font-size: 17.5px;
		}
		ul.work-list p {
			font-size: 15px;
		}
	}
</style>
