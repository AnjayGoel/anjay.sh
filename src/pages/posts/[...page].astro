---
import type { CollectionEntry } from "astro:content";
import { getAllPosts, getPostSortDate, sortMDByDate } from "@/data/post";
import PageLayout from "@/layouts/Base.astro";
import { formatRailDate } from "@/utils/date";
import type { GetStaticPaths, Page } from "astro";

export const getStaticPaths = (async ({ paginate }) => {
	const MAX_POSTS_PER_PAGE = 1000;
	const allPosts = await getAllPosts();
	const allPostsByDate = sortMDByDate(allPosts);
	return paginate(allPostsByDate, { pageSize: MAX_POSTS_PER_PAGE });
}) satisfies GetStaticPaths;

interface Props {
	page: Page<CollectionEntry<"post">>;
}

const { page } = Astro.props;

const meta = {
	description: "Read my collection of posts and the things that interest me",
	title: "Posts",
};

const paginationProps = {
	...(page.url.prev && {
		prevUrl: {
			text: "← Previous",
			url: page.url.prev,
		},
	}),
	...(page.url.next && {
		nextUrl: {
			text: "Next →",
			url: page.url.next,
		},
	}),
};

const totalCount = page.total;
---

<PageLayout meta={meta}>
	<section class="writing" aria-labelledby="writing-label">
		<div class="section-label" id="writing-label">Writing · {totalCount} posts</div>
		<div class="timeline">
			{
				page.data.map((p, idx) => (
					<a
						class="post"
						data-astro-prefetch
						href={`/posts/${p.id}/`}
						style={`--i: ${idx}`}
					>
						<div class="post-rail">
							<time class="post-date" datetime={getPostSortDate(p).toISOString()}>
								{formatRailDate(getPostSortDate(p))}
							</time>
							<span class="post-dot" aria-hidden="true" />
						</div>
						<div class="post-body">
							<h2 class="post-title">{p.data.title}</h2>
							<p class="post-preview">{p.data.description}</p>
						</div>
					</a>
				))
			}
		</div>
		{
			(paginationProps.prevUrl || paginationProps.nextUrl) && (
				<nav class="pagination" aria-label="Pagination">
					{paginationProps.prevUrl && (
						<a class="pag-link prev" data-astro-prefetch href={paginationProps.prevUrl.url}>
							{paginationProps.prevUrl.text}
						</a>
					)}
					{paginationProps.nextUrl && (
						<a class="pag-link next" data-astro-prefetch href={paginationProps.nextUrl.url}>
							{paginationProps.nextUrl.text}
						</a>
					)}
				</nav>
			)
		}
	</section>
</PageLayout>

<style>
	.writing {
		margin-bottom: 96px;
	}

	.timeline {
		display: grid;
		grid-template-columns: var(--rail-width) 1fr;
		column-gap: var(--rail-gap);
		position: relative;
	}
	.timeline::before {
		content: "";
		position: absolute;
		/* 1px line geometrically centered on the rail's right edge */
		left: calc(var(--rail-width) - 0.5px);
		top: 6px;
		bottom: 6px;
		width: 1px;
		background-color: var(--hairline);
		transition: background-color 0.35s ease;
	}
	.post {
		display: contents;
	}
	.post-rail {
		position: relative;
		--rail-pad-top: 4px;
		--rail-date-size: 11.5px;
		--rail-date-lh: 1.4;
		padding-top: var(--rail-pad-top);
		padding-right: 18px;
		text-align: right;
	}
	.post-date {
		font-family: var(--font-mono);
		font-size: var(--rail-date-size);
		color: hsl(var(--theme-text) / 0.6);
		letter-spacing: -0.01em;
		line-height: var(--rail-date-lh);
		white-space: nowrap;
		font-weight: 500;
		font-variant-numeric: tabular-nums;
		font-feature-settings: "tnum";
		transition: color 0.2s ease;
	}
	.post-dot {
		--rail-dot-size: 9px;
		position: absolute;
		/* dot center sits on the rail's right edge (the vertical line) */
		right: calc(-0.5 * var(--rail-dot-size));
		/* dot center sits on date's first-line midline */
		top: calc(var(--rail-pad-top) + 0.5lh);
		font-size: var(--rail-date-size);
		line-height: var(--rail-date-lh);
		transform: translateY(-50%);
		width: var(--rail-dot-size);
		height: var(--rail-dot-size);
		border-radius: 50%;
		background: hsl(var(--theme-bg));
		border: 1.5px solid var(--faint);
		transition: background-color 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
		z-index: 1;
	}
	.post-body {
		padding-bottom: 38px;
	}
	.post-title {
		font-family: var(--font-serif);
		font-weight: 500;
		font-size: 18.5px;
		color: hsl(var(--theme-text));
		line-height: 1.3;
		letter-spacing: -0.012em;
		margin: 0 0 6px;
		text-wrap: balance;
		word-wrap: break-word;
		overflow-wrap: anywhere;
		transition: color 0.2s ease;
	}
	.post:hover .post-title {
		color: hsl(var(--theme-accent));
	}
	.post:hover .post-dot {
		border-color: hsl(var(--theme-accent));
		background: hsl(var(--theme-accent));
		box-shadow: 0 0 0 3px hsl(var(--theme-bg));
	}
	.post:hover .post-date {
		color: hsl(var(--theme-text-muted));
	}
	.post-preview {
		font-size: 16px;
		line-height: 1.55;
		color: hsl(var(--theme-text) / 0.6);
		margin: 0;
		max-width: 58ch;
		word-wrap: break-word;
		overflow-wrap: anywhere;
		display: -webkit-box;
		-webkit-line-clamp: 1;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
	.post:focus-visible {
		outline: 2px solid hsl(var(--theme-accent));
		outline-offset: 4px;
		border-radius: 4px;
	}

	.pagination {
		grid-column: 2;
		margin-top: 8px;
		display: flex;
		gap: 24px;
		align-items: center;
		justify-content: space-between;
	}
	.pag-link {
		display: inline-block;
		padding: 8px 4px;
		font-family: var(--font-mono);
		font-size: 11.5px;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		color: hsl(var(--theme-text-muted));
		text-decoration: underline;
		text-decoration-color: hsl(var(--theme-text) / 0.35);
		text-decoration-thickness: 1px;
		text-underline-offset: 3px;
		transition: color 0.2s ease, text-decoration-color 0.2s ease;
	}
	.pag-link.prev {
		margin-right: auto;
	}
	.pag-link.next {
		margin-left: auto;
	}
	.pag-link:hover {
		color: hsl(var(--theme-accent));
		text-decoration-color: hsl(var(--theme-accent));
	}
	.pag-link:focus-visible {
		outline: 2px solid hsl(var(--theme-accent));
		outline-offset: 3px;
		border-radius: 3px;
	}

	@media (max-width: 720px) {
		.timeline {
			display: block;
		}
		.timeline::before {
			display: none;
		}
		.post {
			display: block;
			padding-bottom: 32px;
		}
		.post-rail {
			text-align: left;
			padding: 0 0 6px 0;
		}
		.post-dot {
			display: none;
		}
		.post-body {
			padding-bottom: 0;
		}
		.pagination {
			margin-top: 16px;
		}
	}

	@media (max-width: 420px) {
		.writing {
			margin-bottom: 64px;
		}
		.post-title {
			font-size: 17px;
		}
		.post-preview {
			font-size: 15px;
		}
		.post-date {
			font-size: 11px;
		}
	}
</style>
