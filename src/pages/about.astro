---
import PageLayout from "@/layouts/Base.astro";
import { Schema } from "astro-seo-schema";

const meta = {
	description: "Anjay Goel — software engineer. About me.",
	title: "About",
};
---

<Schema
	item={{
		"@context": "https://schema.org",
		"@type": "ProfilePage",
		mainEntity: {
			"@type": "Person",
			name: "Anjay Goel",
			image: "https://anjay.sh/avatar.png",
			jobTitle: "Software Engineer",
			worksFor: {
				"@type": "Organization",
				name: "Dashtoon",
			},
			alumniOf: {
				"@type": "CollegeOrUniversity",
				name: "IIT Kharagpur",
			},
			sameAs: ["https://www.linkedin.com/in/anjaygoel/", "https://github.com/anjaygoel"],
		},
	}}
/>

<PageLayout meta={meta}>
	<section class="about" aria-labelledby="about-label">
		<div class="section-label" id="about-label">About</div>
		<div class="prose">
			<p>
				I'm Anjay — a software engineer based in India. I currently work at <a
					href="https://www.linkedin.com/company/dashtoon/"
					rel="noreferrer"
					target="_blank">Dashtoon</a
				> on backend &amp; mobile systems. Before that, I graduated from IIT Kharagpur in 2023.
			</p>
			<p>
				I write here, occasionally, about software internals — containers, async I/O, debugging — with
				the occasional detour into economics &amp; finance. The goal is to think out loud about things
				I'm trying to understand more deeply.
			</p>
			<p>
				You can find me on <a
					href="https://github.com/anjaygoel"
					rel="noreferrer"
					target="_blank">GitHub</a
				>, <a
					href="https://www.linkedin.com/in/anjaygoel/"
					rel="noreferrer"
					target="_blank">LinkedIn</a
				>, or by <a href="mailto:anjay.goel@gmail.com">email</a>.
			</p>
		</div>
	</section>
</PageLayout>

<style>
	.about {
		margin-bottom: 64px;
	}
	.section-label {
		font-family: var(--font-sans);
		font-size: 11.5px;
		font-weight: 500;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: hsl(var(--theme-text) / 0.6);
		margin-bottom: 36px;
	}
	.prose p {
		font-family: var(--font-serif);
		font-size: 17.5px;
		line-height: 1.75;
		color: hsl(var(--theme-text));
		margin: 0 0 22px;
		max-width: 64ch;
		text-wrap: pretty;
		word-wrap: break-word;
		overflow-wrap: anywhere;
	}
	.prose p:last-child {
		margin-bottom: 0;
	}
	.prose a {
		color: hsl(var(--theme-text-muted));
		border-bottom: 1px solid var(--hairline);
		padding-bottom: 1px;
		transition: color 0.2s ease, border-color 0.2s ease;
	}
	.prose a:hover {
		color: hsl(var(--theme-accent));
		border-color: hsl(var(--theme-accent));
	}
	.prose a:focus-visible {
		outline: 2px solid hsl(var(--theme-accent));
		outline-offset: 3px;
		border-radius: 3px;
	}

	@media (max-width: 720px) {
		.prose p {
			font-size: 17px;
			line-height: 1.7;
		}
	}
	@media (max-width: 420px) {
		.section-label {
			margin-bottom: 26px;
		}
		.prose p {
			font-size: 16.5px;
		}
	}
</style>
