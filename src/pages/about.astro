---
import PageLayout from "@/layouts/Base.astro";
import { siteConfig } from "@/site-config";
import { Schema } from "astro-seo-schema";

const profile = siteConfig.profile;
const authorName = profile?.name ?? siteConfig.author;

const meta = {
	description: `${authorName} — about me.`,
	title: "About",
};

const personSameAs = [
	profile?.linkedin,
	profile?.github,
	profile?.twitter,
	profile?.mastodon,
].filter((s): s is string => Boolean(s));

const avatarUrl = profile?.avatar ? new URL(profile.avatar, Astro.site).toString() : undefined;
---

<Schema
	item={{
		"@context": "https://schema.org",
		"@type": "ProfilePage",
		mainEntity: {
			"@type": "Person",
			name: authorName,
			...(avatarUrl ? { image: avatarUrl } : {}),
			...(profile?.jobTitle ? { jobTitle: profile.jobTitle } : {}),
			...(profile?.employer
				? {
						worksFor: {
							"@type": "Organization",
							name: profile.employer,
							...(profile.employerUrl ? { url: profile.employerUrl } : {}),
						},
					}
				: {}),
			...(profile?.alumni
				? {
						alumniOf: {
							"@type": "CollegeOrUniversity",
							name: profile.alumni,
						},
					}
				: {}),
			...(personSameAs.length ? { sameAs: personSameAs } : {}),
		},
	}}
/>

<PageLayout meta={meta}>
	<section class="about" aria-labelledby="about-label">
		<div class="section-label" id="about-label">About</div>
		<ul class="bio">
			<li>
				🚀 Software Engineer at <a
					href={profile?.employerUrl ?? "#"}
					rel="noreferrer"
					target="_blank">{profile?.employer ?? ""}</a
				>
			</li>
			<li>🎓 {profile?.alumni ?? ""} graduate (2023)</li>
			<li>📝 Occasional blogger on tech, economics, and everything in between</li>
		</ul>
		<p class="bio-foot">
			You can find me on <a
				href={profile?.github ?? "#"}
				rel="noreferrer"
				target="_blank">GitHub</a
			>, <a
				href={profile?.linkedin ?? "#"}
				rel="noreferrer"
				target="_blank">LinkedIn</a
			>, or by <a href={`mailto:${profile?.email ?? ""}`}>email</a>.
		</p>
	</section>
</PageLayout>

<style>
	.about {
		margin-bottom: 64px;
	}
	ul.bio {
		list-style: disc;
		list-style-position: inside;
		font-family: var(--font-serif);
		font-size: 17.5px;
		line-height: 1.75;
		color: hsl(var(--theme-text));
		margin: 0 0 28px;
		padding: 0;
	}
	ul.bio li {
		margin-bottom: 6px;
		text-wrap: pretty;
		word-wrap: break-word;
		overflow-wrap: anywhere;
	}
	ul.bio li:last-child {
		margin-bottom: 0;
	}
	.bio-foot {
		font-family: var(--font-serif);
		font-size: 17.5px;
		line-height: 1.75;
		color: hsl(var(--theme-text));
		margin: 0;
		max-width: var(--reading-width);
	}
	.bio a,
	.bio-foot a {
		color: hsl(var(--theme-text));
		text-decoration: underline;
		text-decoration-color: hsl(var(--theme-text) / 0.35);
		text-decoration-thickness: 1px;
		text-underline-offset: 3px;
		transition: color 0.2s ease, text-decoration-color 0.2s ease;
	}
	.bio a:hover,
	.bio-foot a:hover {
		color: hsl(var(--theme-accent));
		text-decoration-color: hsl(var(--theme-accent));
	}
	.bio a:focus-visible,
	.bio-foot a:focus-visible {
		outline: 2px solid hsl(var(--theme-accent));
		outline-offset: 3px;
		border-radius: 3px;
	}

	@media (max-width: 720px) {
		ul.bio,
		.bio-foot {
			font-size: 17px;
			line-height: 1.7;
		}
	}
	@media (max-width: 420px) {
		ul.bio,
		.bio-foot {
			font-size: 16.5px;
		}
	}
</style>
