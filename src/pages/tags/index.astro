---
import { getAllPosts, getUniqueTagsWithCount } from "@/data/post";
import PageLayout from "@/layouts/Base.astro";

const allPosts = await getAllPosts();
const allTags = getUniqueTagsWithCount(allPosts);

const meta = {
	description: "A list of all the topics I've written about in my posts",
	title: "Topics",
};
---

<PageLayout meta={meta}>
	<section class="topics" aria-labelledby="topics-label">
		<div class="section-label" id="topics-label">Topics</div>
		<p class="topics-list">
			{
				allTags.map(([tag, val]: [string, number], i: number) => (
					<>
						{i > 0 && <span class="sep">·</span>}
						<a
							data-astro-prefetch
							href={`/tags/${tag}/`}
							title={`View posts with the tag: ${tag}`}
						>
							{tag} <span class="count">({val})</span>
						</a>
					</>
				))
			}
		</p>
	</section>
</PageLayout>

<style>
	.topics {
		margin-bottom: 64px;
	}
	.section-label {
		font-family: var(--font-sans);
		font-size: 11.5px;
		font-weight: 500;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: hsl(var(--theme-text) / 0.6);
		margin-bottom: 36px;
	}
	.topics-list {
		font-family: var(--font-sans);
		font-size: 13.5px;
		color: hsl(var(--theme-text) / 0.6);
		line-height: 2;
		max-width: 58ch;
		margin: 0;
	}
	.topics-list a {
		color: hsl(var(--theme-text-muted));
		transition: color 0.2s ease;
	}
	.topics-list a:hover {
		color: hsl(var(--theme-accent));
	}
	.topics-list a:focus-visible {
		outline: 2px solid hsl(var(--theme-accent));
		outline-offset: 3px;
		border-radius: 3px;
	}
	.topics-list .count {
		font-family: var(--font-mono);
		font-size: 11px;
		color: var(--faint);
		font-variant-numeric: tabular-nums;
		font-feature-settings: "tnum";
	}
	.topics-list .sep {
		color: var(--faint);
		margin: 0 7px;
	}

	@media (max-width: 420px) {
		.section-label {
			margin-bottom: 26px;
		}
		.topics-list {
			font-size: 12.5px;
		}
	}
</style>
