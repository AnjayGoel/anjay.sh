---
import type { CollectionEntry } from "astro:content";
import { getAllPosts, getPostSortDate, getUniqueTags, sortMDByDate } from "@/data/post";
import PageLayout from "@/layouts/Base.astro";
import type { GetStaticPaths, Page } from "astro";

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
	const allPosts = await getAllPosts();
	const allPostsByDate = sortMDByDate(allPosts);
	const uniqueTags = getUniqueTags(allPostsByDate);

	return uniqueTags.flatMap((tag: string) => {
		const filterPosts = allPostsByDate.filter((post) => post.data.tags.includes(tag));
		return paginate(filterPosts, {
			pageSize: 10,
			params: { tag },
		});
	});
};

interface Props {
	page: Page<CollectionEntry<"post">>;
}

const { page } = Astro.props;
const { tag } = Astro.params;

const meta = {
	description: `View all posts with the tag - ${tag}`,
	title: `Tag: ${tag}`,
};

const paginationProps = {
	...(page.url.prev && {
		prevUrl: {
			text: "← Previous",
			url: page.url.prev,
		},
	}),
	...(page.url.next && {
		nextUrl: {
			text: "Next →",
			url: page.url.next,
		},
	}),
};

const railFormatter = new Intl.DateTimeFormat("en-US", {
	day: "numeric",
	month: "short",
	year: "numeric",
});
const formatRailDate = (date: Date) => railFormatter.format(date);
---

<PageLayout meta={meta}>
	<section class="writing" aria-labelledby="writing-label">
		<div class="section-label" id="writing-label">
			Tagged: {tag} · {page.total} {page.total === 1 ? "post" : "posts"}
		</div>
		<div class="topics-back">
			<a data-astro-prefetch href="/tags/">← All topics</a>
		</div>
		<div class="timeline">
			{
				page.data.map((p) => (
					<a class="post" data-astro-prefetch href={`/posts/${p.slug}/`}>
						<div class="post-rail">
							<time class="post-date" datetime={getPostSortDate(p).toISOString()}>
								{formatRailDate(getPostSortDate(p))}
							</time>
							<span class="post-dot" aria-hidden="true" />
						</div>
						<div class="post-body">
							<h2 class="post-title">{p.data.title}</h2>
							<p class="post-preview">{p.data.description}</p>
						</div>
					</a>
				))
			}
		</div>
		{
			(paginationProps.prevUrl || paginationProps.nextUrl) && (
				<nav class="pagination" aria-label="Pagination">
					{paginationProps.prevUrl && (
						<a class="pag-link prev" data-astro-prefetch href={paginationProps.prevUrl.url}>
							{paginationProps.prevUrl.text}
						</a>
					)}
					{paginationProps.nextUrl && (
						<a class="pag-link next" data-astro-prefetch href={paginationProps.nextUrl.url}>
							{paginationProps.nextUrl.text}
						</a>
					)}
				</nav>
			)
		}
	</section>
</PageLayout>

<style>
	.writing {
		margin-bottom: 96px;
	}
	.section-label {
		font-family: var(--font-sans);
		font-size: 11.5px;
		font-weight: 500;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: hsl(var(--theme-text) / 0.6);
		margin-bottom: 16px;
	}
	.topics-back {
		font-family: var(--font-sans);
		font-size: 13.5px;
		margin-bottom: 36px;
	}
	.topics-back a {
		color: hsl(var(--theme-text-muted));
		border-bottom: 1px solid var(--hairline);
		padding-bottom: 1px;
		transition: color 0.2s ease, border-color 0.2s ease;
	}
	.topics-back a:hover {
		color: hsl(var(--theme-accent));
		border-color: hsl(var(--theme-accent));
	}
	.topics-back a:focus-visible {
		outline: 2px solid hsl(var(--theme-accent));
		outline-offset: 3px;
		border-radius: 3px;
	}

	.timeline {
		display: grid;
		grid-template-columns: 110px 1fr;
		column-gap: 36px;
		position: relative;
	}
	.timeline::before {
		content: "";
		position: absolute;
		left: 110px;
		top: 6px;
		bottom: 6px;
		width: 1px;
		background-color: var(--hairline);
		transition: background-color 0.35s ease;
	}
	.post {
		display: contents;
	}
	.post-rail {
		position: relative;
		padding-top: 4px;
		text-align: right;
		padding-right: 18px;
	}
	.post-date {
		font-family: var(--font-mono);
		font-size: 11.5px;
		color: hsl(var(--theme-text) / 0.6);
		letter-spacing: -0.01em;
		line-height: 1.4;
		white-space: nowrap;
		font-weight: 500;
		font-variant-numeric: tabular-nums;
		font-feature-settings: "tnum";
		transition: color 0.2s ease;
	}
	.post-dot {
		position: absolute;
		right: -4px;
		top: 11px;
		width: 9px;
		height: 9px;
		border-radius: 50%;
		background: hsl(var(--theme-bg));
		border: 1.5px solid var(--faint);
		transition: background-color 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
		z-index: 1;
	}
	.post-body {
		padding-bottom: 38px;
	}
	.post-title {
		font-family: var(--font-serif);
		font-weight: 500;
		font-size: 18.5px;
		color: hsl(var(--theme-text));
		line-height: 1.3;
		letter-spacing: -0.012em;
		margin: 0 0 6px;
		text-wrap: balance;
		word-wrap: break-word;
		overflow-wrap: anywhere;
		transition: color 0.2s ease;
	}
	.post:hover .post-title {
		color: hsl(var(--theme-accent));
	}
	.post:hover .post-dot {
		border-color: hsl(var(--theme-accent));
		background: hsl(var(--theme-accent));
		box-shadow: 0 0 0 3px hsl(var(--theme-bg));
	}
	.post:hover .post-date {
		color: hsl(var(--theme-text-muted));
	}
	.post-preview {
		font-size: 16px;
		line-height: 1.55;
		color: hsl(var(--theme-text) / 0.6);
		margin: 0;
		max-width: 58ch;
		word-wrap: break-word;
		overflow-wrap: anywhere;
		display: -webkit-box;
		-webkit-line-clamp: 1;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
	.post:focus-visible {
		outline: 2px solid hsl(var(--theme-accent));
		outline-offset: 4px;
		border-radius: 4px;
	}

	.pagination {
		grid-column: 2;
		margin-top: 8px;
		display: flex;
		gap: 24px;
		align-items: center;
		justify-content: space-between;
	}
	.pag-link {
		font-family: var(--font-mono);
		font-size: 11.5px;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		color: hsl(var(--theme-text-muted));
		border-bottom: 1px solid var(--hairline);
		padding-bottom: 1px;
		transition: color 0.2s ease, border-color 0.2s ease;
	}
	.pag-link.prev {
		margin-right: auto;
	}
	.pag-link.next {
		margin-left: auto;
	}
	.pag-link:hover {
		color: hsl(var(--theme-accent));
		border-color: hsl(var(--theme-accent));
	}
	.pag-link:focus-visible {
		outline: 2px solid hsl(var(--theme-accent));
		outline-offset: 3px;
		border-radius: 3px;
	}

	@media (max-width: 720px) {
		.timeline {
			display: block;
		}
		.timeline::before {
			display: none;
		}
		.post {
			display: block;
			padding-bottom: 32px;
		}
		.post-rail {
			text-align: left;
			padding: 0 0 6px 0;
		}
		.post-dot {
			display: none;
		}
		.post-body {
			padding-bottom: 0;
		}
		.pagination {
			margin-top: 16px;
		}
	}

	@media (max-width: 420px) {
		.section-label {
			margin-bottom: 16px;
		}
		.writing {
			margin-bottom: 64px;
		}
		.post-title {
			font-size: 17px;
		}
		.post-preview {
			font-size: 15px;
		}
		.post-date {
			font-size: 11px;
		}
	}
</style>
